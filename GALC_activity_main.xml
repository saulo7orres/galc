<?xml version="1.0" encoding="utf-8"?>

<!-- Curso: Análise e Desenvolvimento de Sistemas
    Aluno: Saulo Torres de Oliveira Assis
    Professor: André Gustavo
    Projeto: GALC - Inteligência em cada gota-->

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="30dp"
    android:background="#202124"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GALC"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Inteligência em cada gota"
        android:textColor="#BDC1C6"
        android:textSize="16sp"
        android:layout_marginBottom="40dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Valor da Gasolina"
        android:textColor="#FFFFFF"
        android:textSize="16sp" />

    <EditText
        android:id="@+id/idValorGasolina"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#3B82F6"
        android:hint="0.00"
        android:inputType="numberDecimal"
        android:textColor="#FFFFFF"
        android:textColorHint="#5F6368"
        android:textAlignment="center"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Valor do Álcool"
        android:textColor="#FFFFFF"
        android:textSize="16sp" />

    <EditText
        android:id="@+id/idValorAlcool"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#3B82F6"
        android:hint="0.00"
        android:inputType="numberDecimal"
        android:textColor="#FFFFFF"
        android:textColorHint="#5F6368"
        android:textAlignment="center"
        android:layout_marginBottom="30dp" />

    <Button
        android:id="@+id/idCalcula"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#3B82F6"
        android:text="Verifica"
        android:textColor="#FFFFFF" />

    <TextView
        android:id="@+id/txtResultado"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:textAlignment="center"
        android:textColor="#4ADE80"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="Desenvolvido por Saulo Torres"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:alpha="0.6" />

</LinearLayout>